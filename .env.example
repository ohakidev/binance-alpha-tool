# Environment variables for Binance Alpha Tool
# Local dev can use SQLite, but Vercel production should use a persistent Postgres/Neon URL.
# Examples:
#   Local:  DATABASE_URL="file:./dev.db"
#   Vercel: DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL=""



# Moralis API (Optional - only if using Web3 features)
MORALIS_API_KEY=""

# Telegram Bot (Optional - only if using notifications)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_LANGUAGE="th"

# Application URLs
# Development example:
#   NEXT_PUBLIC_APP_URL="http://localhost:3000"
#   APP_URL="http://localhost:3000"
# Production example:
#   NEXT_PUBLIC_APP_URL="https://alpha-tracker.example.com"
#   APP_URL="https://alpha-tracker.example.com"
NEXT_PUBLIC_APP_URL=""
APP_URL=""

# Binance Alpha API Configuration
# Primary API endpoint (official Binance upstream)
BINANCE_ALPHA_API_URL="https://www.binance.com/bapi/defi/v1/public/wallet-direct/buw/wallet/cex/alpha/all/token/list"




# API Cache duration (in milliseconds) - Default: 5 minutes
ALPHA_CACHE_DURATION="300000"

# Auto-sync interval (in milliseconds) - Default: 7 seconds
ALPHA_SYNC_INTERVAL="7000"
NEXT_PUBLIC_ALPHA_SYNC_INTERVAL="7000"

# Cron Job Security Key (for scheduled sync endpoint)
CRON_SECRET=""
